[Unit]
Description=Pi MPD HTTP Bridge
After=network.target mopidy.service
Wants=mopidy.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/piserver
ExecStart=/home/pi/piserver/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
Environment=PATH=/home/pi/piserver/venv/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
