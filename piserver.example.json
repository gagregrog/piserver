{
  "stereo_sensor": {
    "enabled": false,
    "address": "0x48",
    "channel": 0,
    "gain": 1,
    "on_threshold": 2.0,
    "off_threshold": 1.5
  },
  "volume": {
    "up": "volumeUp",
    "down": "volumeDown",
    "floor_presses": 40,
    "startup_presses": 15
  },
  "quickplay": [
    {
      "items": [
        { "artist": "Example Artist", "album": "Example Album" },
        { "artist": "Another Artist", "album": null }
      ]
    },
    { "shuffle": true }
  ],
  "ir": [
    {
      "name": "power",
      "label": "Power",
      "class": "system",
      "sirc": { "address": "0x10", "command": "0x00" },
      "repeat": 3,
      "delay": 3.0
    },
    {
      "name": "audio",
      "label": "Music",
      "class": "input",
      "default": true,
      "sirc": { "address": "0x10", "command": "0x00" },
      "repeat": 3,
      "delay": 0.5
    },
    {
      "name": "volumeDown",
      "label": "Down",
      "class": "volume",
      "qty": true,
      "floor": true,
      "sirc": { "address": "0x10", "command": "0x00" },
      "repeat": 3,
      "delay": 0.1
    },
    {
      "name": "volumeUp",
      "label": "Up",
      "class": "volume",
      "qty": true,
      "startup": true,
      "sirc": { "address": "0x10", "command": "0x00" },
      "repeat": 3,
      "delay": 0.1
    }
  ]
}
